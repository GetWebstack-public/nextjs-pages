{
  "name": "nextjs-pages",
  "version": "1.0.0",
  "registry": {
    "mode": "local"
  },
  "services": [
    {
      "name": "nextjs-pages",
      "path": ".",
      "port": 3000,
      "hosts": ["nextjs-pages.nextjs-pages.local.getwebstack.dev"],
      "fileSync": true,
      "fileSyncIgnore": [
        "/.git",
        "/.idea",
        "/.vscode",
        "/.DS_Store",
        "node_modules/",
        ".next/",
        "dist/",
        "build/",
        "coverage/",
        ".turbo/",
        "*.log"
      ],
      "dockerfile": ".gws/services/nextjs-pages/Dockerfile",
      "manifests": ".gws/services/nextjs-pages/k8s"
    }
  ],
  "provision": {
    "environments": {
      "dev": {
        "type": "k3d",
        "default": true
      }
    }
  }
}
